---
import HeaderLink from "./HeaderLink.astro";
import { Image } from "astro:assets";
---

<header
  class="bg-white/80 backdrop-blur-md border-b border-slate-200/80 sticky top-0 z-50 animate-fade-in-up transition-all duration-300 shadow-sm"
>
  <nav class="max-w-5xl mx-auto px-4 h-16 flex items-center justify-between">
    <a
      href="/beaconacademy/"
      class="text-xl font-bold tracking-tight text-slate-900 hover:text-indigo-600 transition-colors flex items-center gap-2 group"
    >
      <Image src="/beaconacademy/logo.png" alt="Beacon Academy Logo" width={32} height={32} class="rounded group-hover:rotate-6 transition-transform" />
      Beacon Academy
    </a>
    <div class="flex gap-4 md:gap-6 items-center overflow-x-auto pb-1 md:pb-0 hide-scrollbar">
      <HeaderLink
        href="/beaconacademy/techtips"
        class="text-sm font-medium text-slate-600 hover:text-indigo-600 transition-colors relative after:absolute after:bottom-0 after:left-0 after:w-full after:h-0.5 after:bg-indigo-600 after:scale-x-0 hover:after:scale-x-100 after:transition-transform after:origin-right hover:after:origin-left whitespace-nowrap"
        >Tech Tips</HeaderLink
      >
      <HeaderLink
        href="/beaconacademy/info"
        class="text-sm font-medium text-slate-600 hover:text-indigo-600 transition-colors relative after:absolute after:bottom-0 after:left-0 after:w-full after:h-0.5 after:bg-indigo-600 after:scale-x-0 hover:after:scale-x-100 after:transition-transform after:origin-right hover:after:origin-left whitespace-nowrap"
        >Info</HeaderLink
      >
      <HeaderLink
        href="/beaconacademy/blog"
        class="text-sm font-medium text-slate-600 hover:text-indigo-600 transition-colors relative after:absolute after:bottom-0 after:left-0 after:w-full after:h-0.5 after:bg-indigo-600 after:scale-x-0 hover:after:scale-x-100 after:transition-transform after:origin-right hover:after:origin-left whitespace-nowrap"
        >Blog</HeaderLink
      >
      <HeaderLink
        href="/beaconacademy/ebooks"
        class="text-sm font-medium text-slate-600 hover:text-indigo-600 transition-colors relative after:absolute after:bottom-0 after:left-0 after:w-full after:h-0.5 after:bg-indigo-600 after:scale-x-0 hover:after:scale-x-100 after:transition-transform after:origin-right hover:after:origin-left whitespace-nowrap"
        >eBooks</HeaderLink
      >
      <HeaderLink
        href="/beaconacademy/templates"
        class="text-sm font-medium text-slate-600 hover:text-indigo-600 transition-colors relative after:absolute after:bottom-0 after:left-0 after:w-full after:h-0.5 after:bg-indigo-600 after:scale-x-0 hover:after:scale-x-100 after:transition-transform after:origin-right hover:after:origin-left whitespace-nowrap"
        >Templates</HeaderLink
      >
      <HeaderLink
        href="/beaconacademy/projects"
        class="text-sm font-medium text-slate-600 hover:text-indigo-600 transition-colors relative after:absolute after:bottom-0 after:left-0 after:w-full after:h-0.5 after:bg-indigo-600 after:scale-x-0 hover:after:scale-x-100 after:transition-transform after:origin-right hover:after:origin-left whitespace-nowrap"
        >Projects</HeaderLink
      >
    </div>
  </nav>
</header>
