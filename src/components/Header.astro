---
import HeaderLink from "./HeaderLink.astro";
---

<header
  class="bg-white/80 backdrop-blur-md border-b border-slate-200/80 sticky top-0 z-50 animate-fade-in-up transition-all duration-300 shadow-sm"
>
  <nav class="max-w-5xl mx-auto px-4 h-16 flex items-center justify-between">
    <a
      href="/"
      class="text-xl font-bold tracking-tight text-slate-900 hover:text-indigo-600 transition-colors flex items-center gap-2 group"
    >
      <span
        class="bg-indigo-600 text-white rounded p-1 group-hover:-rotate-6 transition-transform"
      >
        <svg
          xmlns="http://www.w3.org/2000/svg"
          width="20"
          height="20"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          ><path d="M12 2v20"></path><path
            d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"></path></svg
        >
      </span>
      Academy
    </a>
    <div class="flex gap-6 items-center">
      <HeaderLink
        href="/lessons"
        class="text-sm font-medium text-slate-600 hover:text-indigo-600 transition-colors relative after:absolute after:bottom-0 after:left-0 after:w-full after:h-0.5 after:bg-indigo-600 after:scale-x-0 hover:after:scale-x-100 after:transition-transform after:origin-right hover:after:origin-left"
        >Lessons</HeaderLink
      >
      <HeaderLink
        href="/categories"
        class="text-sm font-medium text-slate-600 hover:text-indigo-600 transition-colors relative after:absolute after:bottom-0 after:left-0 after:w-full after:h-0.5 after:bg-indigo-600 after:scale-x-0 hover:after:scale-x-100 after:transition-transform after:origin-right hover:after:origin-left"
        >Categories</HeaderLink
      >
      <HeaderLink
        href="/about"
        class="text-sm font-medium text-slate-600 hover:text-indigo-600 transition-colors relative after:absolute after:bottom-0 after:left-0 after:w-full after:h-0.5 after:bg-indigo-600 after:scale-x-0 hover:after:scale-x-100 after:transition-transform after:origin-right hover:after:origin-left"
        >About</HeaderLink
      >
    </div>
  </nav>
</header>
