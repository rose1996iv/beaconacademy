---

<div id="progress-container" class="fixed top-0 left-0 w-full h-1 z-[100] bg-transparent pointer-events-none">
  <div id="progress-bar" class="h-full bg-gradient-to-r from-indigo-500 via-purple-500 to-cyan-500 dark:from-indigo-400 dark:via-purple-400 dark:to-cyan-400 w-0 transition-all duration-150 ease-out shadow-[0_0_10px_rgba(99,102,241,0.6)]"></div>
</div>

<script is:inline>
  function updateScrollProgress() {
    const winScroll = document.body.scrollTop || document.documentElement.scrollTop;
    const height = document.documentElement.scrollHeight - document.documentElement.clientHeight;
    // Calculate percentage, maxing at 100
    const scrolled = Math.min(100, Math.max(0, (winScroll / height) * 100));
    const bar = document.getElementById("progress-bar");
    if (bar) {
      bar.style.width = scrolled + "%";
    }
  }

  function setupProgressBar() {
    window.addEventListener("scroll", updateScrollProgress, { passive: true });
    // Run once on load just in case we start halfway down
    updateScrollProgress();
  }

  // Setup on initial load
  setupProgressBar();
  // Listen for view transitions
  document.addEventListener("astro:page-load", setupProgressBar);
  document.addEventListener("astro:before-swap", () => {
      const bar = document.getElementById("progress-bar");
      if(bar) bar.style.width = "0%";
  });
</script>
