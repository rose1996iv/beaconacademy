---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';

const { title, description = 'Academy - Learn Web Development' } = Astro.props;
---

<html lang="en" class="antialiased scroll-smooth">
  <head>
    <BaseHead title={title} description={description} />
  </head>

  <body class="bg-gradient-to-br from-slate-50 to-slate-100 min-h-screen text-slate-900 flex flex-col selection:bg-indigo-300 selection:text-indigo-900">
    <Header />
    <div class="flex-1 w-full">
      <slot />
    </div>
    <Footer />
  </body>
</html>
