---
import { type CollectionEntry, getCollection, render } from 'astro:content';
import BlogPost from '../../layouts/BlogPost.astro';

export async function getStaticPaths() {
	const posts = await getCollection('templates');
	return posts.map((post) => ({
		params: { slug: post.id },
		props: post,
	}));
}
type Props = CollectionEntry<'templates'>;

const post = Astro.props;
const { Content } = await render(post);
---

<BlogPost {...post.data}>
    <div class="not-prose mb-8 flex flex-wrap gap-4">
        {post.data.downloadLink && (
            <a 
                href={post.data.downloadLink} 
                target="_blank" 
                class="inline-flex items-center gap-2 bg-indigo-600 hover:bg-indigo-700 !text-white font-bold py-3 px-8 rounded-xl transition-all shadow-md hover:shadow-lg hover:-translate-y-0.5"
            >
                <span>🎨</span> Get the Template
            </a>
        )}
    </div>
	<Content />
</BlogPost>
