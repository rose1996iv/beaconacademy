---
import BaseHead from "../components/BaseHead.astro";
import Footer from "../components/Footer.astro";
import Header from "../components/Header.astro";
import { SITE_DESCRIPTION, SITE_TITLE } from "../consts";
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />
		<main class="max-w-4xl mx-auto px-4 py-16 sm:py-24">
			<div class="text-center mb-16 animate-fade-in-up">
				<div
					class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-indigo-50 text-indigo-600 text-sm font-medium mb-6 animate-pulse-slow"
				>
					<span class="relative flex h-2 w-2">
						<span
							class="animate-ping-absolute inline-flex h-full w-full rounded-full bg-indigo-400 opacity-75"
						></span>
						<span
							class="relative inline-flex rounded-full h-2 w-2 bg-indigo-500"
						></span>
					</span>
					MTech Student & Educator
				</div>
				<h1
					class="text-4xl sm:text-6xl font-extrabold tracking-tight text-slate-900 mb-6 w-full text-balance"
				>
					Hi, I'm <span
						class="text-transparent bg-clip-text bg-gradient-to-r from-indigo-600 to-cyan-500 hover:from-cyan-500 hover:to-indigo-600 transition-all duration-500 cursor-default"
						>Joseph</span
					>
				</h1>
				<p
					class="text-lg sm:text-xl text-slate-600 max-w-2xl mx-auto leading-relaxed"
				>
					I am currently pursuing an MTech in Computer Science &
					Engineering, specializing in Cybersecurity, AI, and Data
					Science. I am passionate about driving innovation and
					applying these technologies to solve real-world problems.
				</p>
			</div>

			<div
				class="grid sm:grid-cols-2 gap-8 text-left animate-fade-in-up"
				style="animation-delay: 150ms;"
			>
				<div
					class="bg-white p-6 rounded-2xl shadow-sm border border-slate-100/50 hover:shadow-md hover:border-indigo-100 transition-all duration-300 group"
				>
					<h2 class="text-xl font-bold flex items-center gap-2 mb-4">
						<span
							class="bg-indigo-50 text-indigo-600 p-2 rounded-lg group-hover:scale-110 group-hover:bg-indigo-100 transition-all"
							>💼</span
						>
						Experience
					</h2>
					<div class="space-y-4">
						<div>
							<h3 class="font-bold text-slate-900">
								Computer Science Teacher
							</h3>
							<p class="text-sm text-indigo-600 font-medium">
								Victoria Academy, Hakha
							</p>
							<p class="text-xs text-slate-500 mt-1">
								Sept 2022 - Present
							</p>
						</div>
						<div>
							<h3 class="font-bold text-slate-900">Manager</h3>
							<p class="text-sm text-indigo-600 font-medium">
								Beacon Academy
							</p>
							<p class="text-xs text-slate-500 mt-1">
								Apr 2017 - Apr 2019
							</p>
						</div>
					</div>
				</div>

				<div
					class="bg-white p-6 rounded-2xl shadow-sm border border-slate-100/50 hover:shadow-md hover:border-indigo-100 transition-all duration-300 group"
				>
					<h2 class="text-xl font-bold flex items-center gap-2 mb-4">
						<span
							class="bg-indigo-50 text-indigo-600 p-2 rounded-lg group-hover:scale-110 group-hover:bg-indigo-100 transition-all"
							>🎓</span
						>
						Education
					</h2>
					<div class="space-y-4">
						<div>
							<h3 class="font-bold text-slate-900">
								MTech, Computer Science & Engineering
							</h3>
							<p class="text-sm text-indigo-600 font-medium">
								Graphic Era Hill University
							</p>
							<p class="text-xs text-slate-500 mt-1">
								Oct 2024 - July 2026
							</p>
						</div>
						<div>
							<h3 class="font-bold text-slate-900">
								Bachelor of Engineering, Electronics
							</h3>
							<p class="text-sm text-indigo-600 font-medium">
								Technological University (Kalay)
							</p>
							<p class="text-xs text-slate-500 mt-1">
								Dec 2013 - Nov 2019
							</p>
						</div>
					</div>
				</div>

				<div
					class="bg-white p-6 rounded-2xl shadow-sm border border-slate-100/50 hover:shadow-md hover:border-indigo-100 transition-all duration-300 group sm:col-span-2"
				>
					<h2 class="text-xl font-bold flex items-center gap-2 mb-4">
						<span
							class="bg-indigo-50 text-indigo-600 p-2 rounded-lg group-hover:scale-110 group-hover:bg-indigo-100 transition-all"
							>🛠️</span
						>
						Projects & Skills
					</h2>
					<div class="grid sm:grid-cols-2 gap-6">
						<div>
							<h3 class="font-bold text-slate-900 mb-2">
								Projects
							</h3>
							<ul
								class="space-y-2 text-sm text-slate-600 list-none pl-0"
							>
								<li class="flex items-start gap-2">
									<svg
										class="w-4 h-4 text-emerald-500 mt-0.5 shrink-0"
										fill="none"
										viewBox="0 0 24 24"
										stroke="currentColor"
										><path
											stroke-linecap="round"
											stroke-linejoin="round"
											stroke-width="2"
											d="M5 13l4 4L19 7"></path></svg
									>
									<span
										><strong
											>Object Detecting Mini Radar</strong
										> (Arduino IDE)</span>
								</li>
								<li class="flex items-start gap-2">
									<svg
										class="w-4 h-4 text-emerald-500 mt-0.5 shrink-0"
										fill="none"
										viewBox="0 0 24 24"
										stroke="currentColor"
										><path
											stroke-linecap="round"
											stroke-linejoin="round"
											stroke-width="2"
											d="M5 13l4 4L19 7"></path></svg
									>
									<span
										><strong
											>Voice Activated Home Automation</strong
										> (Arduino IDE)</span>
								</li>
							</ul>
						</div>
						<div>
							<h3 class="font-bold text-slate-900 mb-2">
								Top Skills & Certifications
							</h3>
							<div class="flex flex-wrap gap-2">
								<span
									class="bg-slate-50 text-slate-700 px-2 py-1 rounded text-xs border border-slate-200"
									>Cybersecurity</span
								>
								<span
									class="bg-slate-50 text-slate-700 px-2 py-1 rounded text-xs border border-slate-200"
									>AI & Data Science</span
								>
								<span
									class="bg-slate-50 text-slate-700 px-2 py-1 rounded text-xs border border-slate-200"
									>Computer Networking</span
								>
								<span
									class="bg-slate-50 text-slate-700 px-2 py-1 rounded text-xs border border-slate-200"
									>ANZ Cyber Security</span
								>
							</div>
						</div>
					</div>
				</div>
			</div>
		</main>
		<Footer />
	</body>
</html>
