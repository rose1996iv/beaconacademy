---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />
		<main class="max-w-4xl mx-auto px-4 py-16 sm:py-24">
			<div class="text-center mb-16 animate-fade-in-up">
				<div class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-indigo-50 text-indigo-600 text-sm font-medium mb-6 animate-pulse-slow">
					<span class="relative flex h-2 w-2">
					  <span class="animate-ping-absolute inline-flex h-full w-full rounded-full bg-indigo-400 opacity-75"></span>
					  <span class="relative inline-flex rounded-full h-2 w-2 bg-indigo-500"></span>
					</span>
					Welcome to the future
				</div>
				<h1 class="text-4xl sm:text-6xl font-extrabold tracking-tight text-slate-900 mb-6 w-full text-balance">
					Fast, Modern <span class="text-transparent bg-clip-text bg-gradient-to-r from-indigo-600 to-cyan-500 hover:from-cyan-500 hover:to-indigo-600 transition-all duration-500 cursor-default">Education</span>
				</h1>
				<p class="text-lg sm:text-xl text-slate-600 max-w-2xl mx-auto leading-relaxed">
					Dive into dynamic lessons with <a href="https://astro.build/" class="text-indigo-600 font-semibold hover:underline decoration-indigo-200 underline-offset-4">Astro</a>. This template
					serves as a beautifully crafted starting point for anyone looking to build a high-performance educational platform.
				</p>
			</div>

			<div class="grid sm:grid-cols-2 gap-8 text-left animate-fade-in-up" style="animation-delay: 150ms;">
				<div class="bg-white p-6 rounded-2xl shadow-sm border border-slate-100/50 hover:shadow-md hover:border-indigo-100 transition-all duration-300 group">
					<h2 class="text-xl font-bold flex items-center gap-2 mb-3">
						<span class="bg-indigo-50 text-indigo-600 p-2 rounded-lg group-hover:scale-110 group-hover:bg-indigo-100 transition-all">🚀</span> 
						Quick Start
					</h2>
					<p class="text-slate-600 mb-4 text-sm leading-relaxed">Get up and running instantly. Here's a few ideas:</p>
					<ul class="space-y-2 text-sm text-slate-600 list-none pl-0">
						<li class="flex items-center gap-2"><svg class="w-4 h-4 text-emerald-500" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg> Edit this page in <code class="bg-slate-50 text-slate-800 px-1.5 py-0.5 rounded text-xs ml-1 border border-slate-200">src/pages/index.astro</code></li>
						<li class="flex items-center gap-2"><svg class="w-4 h-4 text-emerald-500" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg> Customize <code class="bg-slate-50 text-slate-800 px-1.5 py-0.5 rounded text-xs ml-1 border border-slate-200">Header.astro</code></li>
						<li class="flex items-center gap-2"><svg class="w-4 h-4 text-emerald-500" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg> Explore content in <code class="bg-slate-50 text-slate-800 px-1.5 py-0.5 rounded text-xs ml-1 border border-slate-200">src/content/</code></li>
					</ul>
				</div>

				<div class="bg-white p-6 rounded-2xl shadow-sm border border-slate-100/50 hover:shadow-md hover:border-indigo-100 transition-all duration-300 group">
					<h2 class="text-xl font-bold flex items-center gap-2 mb-3">
						<span class="bg-indigo-50 text-indigo-600 p-2 rounded-lg group-hover:scale-110 group-hover:bg-indigo-100 transition-all">💡</span> 
						Resources
					</h2>
					<p class="text-slate-600 mb-4 text-sm leading-relaxed">Need help? The Astro community has you covered.</p>
					<div class="space-y-3">
						<a href="https://docs.astro.build/" class="block px-4 py-3 bg-slate-50 hover:bg-slate-100 text-slate-700 rounded-xl transition-colors font-medium text-sm flex items-center justify-between group/link">
							Read the documentation
							<svg class="w-4 h-4 text-slate-400 group-hover/link:text-indigo-600 group-hover/link:translate-x-1 transition-all" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path></svg>
						</a>
						<a href="https://astro.build/chat" class="block px-4 py-3 bg-indigo-50 hover:bg-indigo-100 text-indigo-700 rounded-xl transition-colors font-medium text-sm flex items-center justify-between group/link">
							Join us on Discord
							<svg class="w-4 h-4 text-indigo-400 group-hover/link:text-indigo-600 group-hover/link:translate-x-1 transition-all" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path></svg>
						</a>
					</div>
				</div>
			</div>
		</main>
		<Footer />
	</body>
</html>
