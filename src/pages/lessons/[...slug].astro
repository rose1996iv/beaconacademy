---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import ProgressToggle from '../../components/ProgressToggle';

export async function getStaticPaths() {
  const lessons = await getCollection('lessons');
  return lessons.map(lesson => ({
    params: { slug: lesson.slug },
    props: { lesson },
  }));
}

const { lesson } = Astro.props;
const { Content } = await lesson.render();
---

<Layout title={lesson.data.title}>
  <div class="max-w-4xl mx-auto px-4 py-8 flex gap-8">
    <article class="flex-1 prose prose-slate max-w-none">
      <header class="mb-8">
        <h1 class="text-4xl font-bold text-slate-900 mb-4">{lesson.data.title}</h1>
        <div class="flex gap-4 text-sm text-slate-600 mb-6 font-medium">
          <span class="bg-indigo-50 text-indigo-700 px-2 py-1 rounded">{lesson.data.category}</span>
          <span class="bg-emerald-50 text-emerald-700 px-2 py-1 rounded">{lesson.data.difficulty}</span>
          <span>{lesson.data.pubDate.toLocaleDateString()}</span>
        </div>
        <div class="flex justify-between items-center bg-slate-50 p-4 rounded-lg border border-slate-100">
          <p class="text-slate-700 m-0">{lesson.data.description}</p>
          <ProgressToggle client:load slug={lesson.slug} />
        </div>
      </header>
      
      <div class="mt-8">
        <Content />
      </div>
    </article>
    
    <aside class="w-64 hidden lg:block shrink-0">
      <div class="sticky top-8">
        <h3 class="text-sm font-semibold text-slate-900 uppercase tracking-wider mb-4">Table of Contents</h3>
        <nav class="space-y-2">
           <!-- Astro TOC plugin or simple mapping of headings could go here. For simplicity, we are leaving this static for this example structure but can be easily expanded. -->
           <a href="#" class="block text-sm text-slate-600 hover:text-indigo-600 transition-colors">Back to top</a>
        </nav>
      </div>
    </aside>
  </div>
</Layout>
