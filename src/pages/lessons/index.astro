---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';

const lessons = await getCollection('lessons');

lessons.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
---

<Layout title="Lessons | Academy">
  <main class="max-w-5xl mx-auto px-4 py-12">
    <header class="mb-12">
      <h1 class="text-5xl font-extrabold text-slate-900 tracking-tight mb-4">Lessons</h1>
      <p class="text-xl text-slate-600 max-w-2xl">Browse our collection of educational modules to enhance your web development skills.</p>
    </header>

    <div class="grid gap-8 sm:grid-cols-2 lg:grid-cols-3">
      {
        lessons.map((lesson) => (
          <article class="group relative flex flex-col bg-white rounded-2xl shadow-sm border border-slate-200 hover:shadow-md hover:border-indigo-300 transition-all overflow-hidden">
            <a href={`/beaconacademy/lessons/${lesson.slug}/`} class="absolute inset-0 z-10">
              <span class="sr-only">View {lesson.data.title}</span>
            </a>
            
            <div class="p-6 flex-1 flex flex-col">
              <div class="flex gap-2 items-center mb-4">
                <span class="inline-flex items-center rounded-md bg-indigo-50 px-2 py-1 text-xs font-medium text-indigo-700 ring-1 ring-inset ring-indigo-700/10">
                  {lesson.data.category}
                </span>
                <span class="inline-flex items-center rounded-md bg-emerald-50 px-2 py-1 text-xs font-medium text-emerald-700 ring-1 ring-inset ring-emerald-600/20">
                  {lesson.data.difficulty}
                </span>
              </div>
              
              <h2 class="text-xl font-bold text-slate-900 mb-2 group-hover:text-indigo-600 transition-colors">
                {lesson.data.title}
              </h2>
              
              <p class="text-slate-600 text-sm mb-6 flex-1 line-clamp-3">
                {lesson.data.description}
              </p>
              
              <div class="flex items-center text-xs text-slate-500 font-medium mt-auto border-t border-slate-100 pt-4">
                <time datetime={lesson.data.pubDate.toISOString()}>
                  {lesson.data.pubDate.toLocaleDateString(undefined, {
                    year: 'numeric',
                    month: 'short',
                    day: 'numeric',
                  })}
                </time>
              </div>
            </div>
          </article>
        ))
      }
    </div>
  </main>
</Layout>
